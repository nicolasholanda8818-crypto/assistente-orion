# Copie para .env apenas em ambiente local. Nunca versione .env.
# Este arquivo contem somente configuracoes nao sensiveis.
# Segredos de longa duracao pertencem ao cofre criptografado do ORION.
APP_NAME=Orion
APP_ENV=development
ORION_ENV=production
ORION_PUBLIC_URL=https://seu-dominio.com
ORION_ADMIN_PASSWORD=
ORION_MASTER_KEY=
APP_HOST=127.0.0.1
APP_PORT=8000
DATABASE_URL=sqlite:///./database/orion.db
STATIC_DIR=frontend
LOG_DIR=storage/logs
ONBOARDING_CRYPTO_PATH=storage/keys/onboarding.key
PWA_CACHE_NAME=orion-pwa-v34-sidebar-voice-call
DEPLOYMENT_TARGET=local
MANAGED_DATABASE_PROVIDER=sqlite-local
MANAGED_DATABASE_URL_REF=
FILE_STORAGE_BACKEND=local
FILE_STORAGE_PATH=storage/files
FILE_UPLOAD_MAX_BYTES=15728640
FILE_ALLOWED_EXTENSIONS=[".bmp",".csv",".doc",".docx",".gif",".jpeg",".jpg",".json",".md",".pdf",".png",".txt",".webp",".xls",".xlsx"]
FILE_BLOCKED_EXTENSIONS=[".bat",".cmd",".com",".dll",".exe",".html",".hta",".jar",".js",".msi",".php",".ps1",".scr",".sh",".svg",".vbs"]
OBJECT_STORAGE_PROVIDER=
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_REGION=
OBJECT_STORAGE_ACCESS_KEY_REF=
OBJECT_STORAGE_SECRET_KEY_REF=
HORIZONTAL_REPLICAS_ENABLED=false
SESSION_BACKEND=memory
WEBSOCKET_BROKER=memory
MONITORING_ENABLED=true
MODEL_SELECTION_MODE=explicit-only
MODEL_EXTERNAL_CALLS_ENABLED=false
MODEL_REMOTE_HOST_ALLOWLIST=[]
OLLAMA_BASE_URL=http://127.0.0.1:11434
LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY_REF=
AZURE_SPEECH_KEY_REF=
AZURE_SPEECH_REGION=
ELEVENLABS_API_KEY_REF=
OPENAI_TTS_API_KEY_REF=
COQUI_TTS_MODEL_PATH=
WEB_SEARCH_ENABLED=true
WEB_SEARCH_PROVIDER=duckduckgo-html+mojeek
WEB_SEARCH_TIMEOUT_SECONDS=5
WEB_SEARCH_MAX_RESULTS=5
